{
	"name": "my-svelte-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"atlas:convert": "sh scripts/convert-grass-atlas.sh",
		"dev": "vite dev --host 127.0.0.1 --port 4173 --strictPort",
		"build": "vite build",
		"start": "vite preview --host 127.0.0.1 --port 4174 --strictPort",
		"preview": "vite preview --host 127.0.0.1 --port 4174 --strictPort",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
